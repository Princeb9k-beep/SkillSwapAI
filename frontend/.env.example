# Base URL of the SkillSwap AI backend API.
#
# Leave UNSET for the single-app deploy (FastAPI serves this SPA) — the client
# then calls its own origin. Only set this for split local dev, when the Vite dev
# server (:5173) needs to reach the API on a different origin (:8000).
VITE_API_BASE_URL=http://localhost:8000
