# SkillSwap AI — environment configuration
# Copy to `.env` and fill in the real values. `.env` is git-ignored.

# PostgreSQL
# Recommended: paste Render's "Internal Database URL" directly here. It's
# postgres:// — the app rewrites it to postgresql+asyncpg:// automatically
# (see async_database_url in app/config.py). This is what production uses.
DATABASE_URL=

# Alternative: leave DATABASE_URL blank and set these discrete parts instead
# (used for local dev against a non-Render Postgres). DATABASE_URL always
# takes precedence when set.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=skillswapaidb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}

# Redis
REDIS_URL=redis://red-d9d9vt37uimc73aiotig:6379
REDIS_PASSWORD=${REDIS_PASSWORD}

# Groq AI
GROQ_API_KEY=${GROQ_API_KEY}
GROQ_MODEL=llama-3.3-70b-versatile

# App Config
APP_ENV=production
APP_SECRET_KEY=${APP_SECRET_KEY}
APP_DEBUG=False

# Comma-separated list of allowed CORS origins for the frontend (or * for all)
CORS_ORIGINS=*

# Web Push (VAPID) — optional; enables browser push notifications.
# Generate a keypair with:  python -m py_vapid --gen  (or `vapid --gen`)
VAPID_PUBLIC_KEY=${VAPID_PUBLIC_KEY}
VAPID_PRIVATE_KEY=${VAPID_PRIVATE_KEY}
VAPID_SUBJECT=mailto:admin@skillswapai.app
